# Backend Environment Variables for Vital Lens AI

# Database Configuration
DATABASE_URL=postgresql://vitalensai:develop123@postgres:5432/vital_lens_ai
DB_USER=vitalensai
DB_PASSWORD=develop123
DB_NAME=vital_lens_ai
DB_HOST=postgres
DB_PORT=5432
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_ECHO=false

# Redis Configuration
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_POOL_SIZE=10

# RabbitMQ Configuration
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-in-production-12345678
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=1
JWT_REFRESH_EXPIRATION_DAYS=7
JWT_REFRESH_SECRET=your-refresh-secret-key-12345678

# Application Configuration
APP_NAME=Vital Lens AI
APP_VERSION=3.0.0
DEBUG=true
LOG_LEVEL=INFO
ENVIRONMENT=development

# CORS Configuration
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000,http://localhost

# Security Configuration
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_TIMEOUT_MINUTES=15
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL_CHARS=true

# 2FA/MFA Configuration
TOTP_WINDOW=1
TOTP_ISSUER=Vital Lens AI
ENABLE_SMS_2FA=false
ENABLE_EMAIL_2FA=true

# Email Configuration (SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@vitalensai.com
SMTP_FROM_NAME=Vital Lens AI
SMTP_TLS=true

# Encryption Configuration
ENCRYPTION_KEY=your-32-character-encryption-key-here
ENCRYPTION_ALGORITHM=AES-256-GCM

# GDPR Configuration
DATA_RETENTION_DAYS=365
DATA_EXPORT_EXPIRY_DAYS=7
ALLOW_DATA_DELETION=true
GDPR_COMPLIANCE_MODE=true

# HIPAA Configuration
HIPAA_MODE=true
AUDIT_LOG_RETENTION_DAYS=2555
REQUIRE_AUDIT_LOGGING=true

# API Configuration
API_RATE_LIMIT_REQUESTS=100
API_RATE_LIMIT_PERIOD_SECONDS=60
API_REQUEST_TIMEOUT_SECONDS=30
MAX_FILE_UPLOAD_SIZE_MB=100

# Celery Configuration
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_ACCEPT_CONTENT=json
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=true

# AWS Configuration (Optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=vital-lens-ai-data
AWS_S3_EXPIRY_HOURS=24

# Stripe Configuration (Optional)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# OpenAI Configuration (Optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# Twilio Configuration (Optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Sentry Configuration (Optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Feature Flags
ENABLE_USER_REGISTRATION=true
ENABLE_SOCIAL_LOGIN=false
ENABLE_BIOMETRIC_AUTH=false
ENABLE_DATA_EXPORT=true
ENABLE_HEALTH_INSIGHTS=false
ENABLE_ADMIN_PANEL=true

# Model Configuration
ML_MODEL_PATH=/app/models/
TENSORFLOW_MODEL_NAME=vital_lens_model.tflite
MODEL_INFERENCE_TIMEOUT_SECONDS=10
GPU_ENABLED=false

# Logging Configuration
LOG_FORMAT=json
LOG_TO_FILE=true
LOG_FILE_PATH=/var/log/vital-lens/
LOG_MAX_SIZE_MB=100
LOG_BACKUP_COUNT=10

# Monitoring and Metrics
ENABLE_PROMETHEUS=true
PROMETHEUS_PORT=9090
ENABLE_HEALTH_CHECK=true
HEALTH_CHECK_INTERVAL_SECONDS=30

# Session Configuration
SESSION_TIMEOUT_MINUTES=30
SESSION_ABSOLUTE_TIMEOUT_HOURS=24
REMEMBER_ME_DURATION_DAYS=7

# Cache Configuration
CACHE_BACKEND=redis
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=1000

# File Storage
STORAGE_TYPE=local
STORAGE_PATH=/app/storage/
TEMP_PATH=/tmp/vital-lens/

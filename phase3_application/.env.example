# Database Configuration
DATABASE_URL=postgresql://vitalensai:develop123@postgres:5432/vital_lens_ai
DB_USER=vitalensai
DB_PASSWORD=develop123
DB_NAME=vital_lens_ai
DB_HOST=postgres
DB_PORT=5432

# Redis Configuration
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# RabbitMQ Configuration
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-in-production-12345678
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=1
JWT_REFRESH_EXPIRATION_DAYS=7

# Application Configuration
APP_NAME=Vital Lens AI
APP_VERSION=3.0.0
DEBUG=true
LOG_LEVEL=INFO
ENVIRONMENT=development

# CORS Configuration
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# Email Configuration (Optional - for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@vitalensai.com
SMTP_FROM_NAME=Vital Lens AI

# AWS Configuration (Optional - for S3 storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=vital-lens-ai-data

# Security Configuration
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_TIMEOUT_MINUTES=15
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL_CHARS=true

# GDPR Configuration
DATA_RETENTION_DAYS=365
DATA_EXPORT_EXPIRY_DAYS=7
ALLOW_DATA_DELETION=true

# API Configuration
API_RATE_LIMIT_REQUESTS=100
API_RATE_LIMIT_PERIOD_SECONDS=60
API_REQUEST_TIMEOUT_SECONDS=30

# Frontend Configuration
VITE_API_URL=http://localhost:8000/api/v1
VITE_APP_NAME=Vital Lens AI
VITE_DEBUG=true

# Sentry (Error Tracking - Optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Stripe (Payments - Optional)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# OpenAI (for health insights - Optional)
OPENAI_API_KEY=

# Twilio (for SMS 2FA - Optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Frontend Environment Variables for Vital Lens AI

# API Configuration
VITE_API_URL=http://localhost:8000/api/v1
VITE_API_TIMEOUT=30000

# Application Configuration
VITE_APP_NAME=Vital Lens AI
VITE_APP_VERSION=3.0.0
VITE_DEBUG=true

# Feature Flags
VITE_ENABLE_CAMERA=true
VITE_ENABLE_2FA=true
VITE_ENABLE_DATA_EXPORT=true
VITE_ENABLE_HEALTH_INSIGHTS=true
VITE_ENABLE_OFFLINE_MODE=false

# Camera Configuration
VITE_CAMERA_FPS=30
VITE_CAMERA_WIDTH=1280
VITE_CAMERA_HEIGHT=720
VITE_MIN_FACE_DETECTION_CONFIDENCE=0.5
VITE_MIN_MEASUREMENT_DURATION_SECONDS=30
VITE_MAX_MEASUREMENT_DURATION_SECONDS=120

# UI Configuration
VITE_THEME=light
VITE_LANGUAGE=en
VITE_TIMEZONE=UTC

# Measurement Configuration
VITE_HR_MIN_BPM=40
VITE_HR_MAX_BPM=200
VITE_SIGNAL_QUALITY_THRESHOLD=0.6
VITE_CONFIDENCE_THRESHOLD=0.8

# Chart Configuration
VITE_CHART_ANIMATION=true
VITE_CHART_RESPONSIVE=true
VITE_VITALS_HISTORY_DAYS=30

# Third-party Services
VITE_SENTRY_DSN=
VITE_ANALYTICS_ID=
VITE_MIXPANEL_TOKEN=

# Authentication
VITE_TOKEN_REFRESH_THRESHOLD_MINUTES=5
VITE_SESSION_TIMEOUT_MINUTES=30

# Accessibility
VITE_ENABLE_SCREEN_READER_SUPPORT=true
VITE_ENABLE_HIGH_CONTRAST_MODE=false

# Performance
VITE_ENABLE_COMPRESSION=true
VITE_ENABLE_CACHING=true
VITE_CACHE_DURATION_HOURS=24

# Data
VITE_MAX_LOCAL_STORAGE_MB=10
VITE_AUTO_SYNC_INTERVAL_SECONDS=60
